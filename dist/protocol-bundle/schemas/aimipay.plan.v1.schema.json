{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "amount_atomic": {
      "minimum": 0,
      "title": "Amount Atomic",
      "type": "integer"
    },
    "billing_interval": {
      "default": "month",
      "title": "Billing Interval",
      "type": "string"
    },
    "description": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Description"
    },
    "enabled": {
      "default": true,
      "title": "Enabled",
      "type": "boolean"
    },
    "features": {
      "items": {
        "type": "string"
      },
      "title": "Features",
      "type": "array"
    },
    "name": {
      "title": "Name",
      "type": "string"
    },
    "plan_id": {
      "title": "Plan Id",
      "type": "string"
    },
    "subscribe_path": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Subscribe Path"
    }
  },
  "required": [
    "plan_id",
    "name",
    "amount_atomic"
  ],
  "title": "MerchantPlan",
  "type": "object"
}
