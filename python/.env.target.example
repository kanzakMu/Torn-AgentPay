AIMIPAY_REPOSITORY_ROOT=<repository-root>
AIMIPAY_FULL_HOST=http://127.0.0.1:9090
AIMIPAY_SETTLEMENT_BACKEND=local_smoke
AIMIPAY_CHAIN_ID=31337

AIMIPAY_SERVICE_NAME=Research Copilot
AIMIPAY_SERVICE_DESCRIPTION=Pay-per-use research and market data

AIMIPAY_SELLER_ADDRESS=TRX_SELLER
AIMIPAY_SELLER_PRIVATE_KEY=seller_private_key
AIMIPAY_CONTRACT_ADDRESS=TRX_CONTRACT
AIMIPAY_TOKEN_ADDRESS=TRX_USDT
AIMIPAY_NETWORK_NAME=tron-nile
AIMIPAY_FAUCET_URL=https://nileex.io/join/getJoinPage
AIMIPAY_FUNDING_GUIDE_URL=https://developers.tron.network/docs/getting-testnet-tokens
AIMIPAY_MIN_TRX_BALANCE_SUN=1000000
AIMIPAY_MIN_TOKEN_BALANCE_ATOMIC=1000000

# Point this at the long-lived runtime database when rerunning a real environment.
AIMIPAY_SQLITE_PATH=<repository-root>/python/.dry-run/target/target-payments.db

# Optional tuning for target dry run.
AIMIPAY_PROCESSING_LOCK_TTL_S=180
AIMIPAY_MAX_CONFIRMATION_ATTEMPTS=6
