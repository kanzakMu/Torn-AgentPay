AIMIPAY_REPOSITORY_ROOT=e:/trade/aimicropay-tron
AIMIPAY_FULL_HOST=https://your-nile-merchant.example
AIMIPAY_SETTLEMENT_BACKEND=claim_script
AIMIPAY_CHAIN_ID=3448148188

AIMIPAY_SERVICE_NAME=Research Copilot
AIMIPAY_SERVICE_DESCRIPTION=Pay-per-use research and market data

AIMIPAY_SELLER_ADDRESS=TRON_NILE_SELLER_ADDRESS
AIMIPAY_SELLER_PRIVATE_KEY=replace_with_real_nile_private_key
AIMIPAY_CONTRACT_ADDRESS=TRON_NILE_CONTRACT_ADDRESS
AIMIPAY_TOKEN_ADDRESS=TRON_NILE_USDT_ADDRESS
AIMIPAY_NETWORK_NAME=tron-nile
AIMIPAY_FAUCET_URL=https://nileex.io/join/getJoinPage
AIMIPAY_FUNDING_GUIDE_URL=https://developers.tron.network/docs/getting-testnet-tokens
AIMIPAY_MIN_TRX_BALANCE_SUN=1000000
AIMIPAY_MIN_TOKEN_BALANCE_ATOMIC=1000000

# Point this at the long-lived runtime database on your staging or testnet host.
AIMIPAY_SQLITE_PATH=e:/trade/aimicropay-tron/python/target-nile-payments.db

# Optional tuning for testnet rollout.
AIMIPAY_PROCESSING_LOCK_TTL_S=180
AIMIPAY_MAX_CONFIRMATION_ATTEMPTS=6
