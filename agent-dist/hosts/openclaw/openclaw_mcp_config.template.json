{
  "_comment": "OpenClaw-style MCP registration. After installation, the installer rewrites the command, repo root, Python path, and merchant URL automatically.",
  "mcpServers": {
    "aimipay-agent": {
      "transport": "stdio",
      "command": "C:\\path\\to\\python.exe",
      "args": [
        "-m",
        "agent_entrypoints.aimipay_mcp_stdio"
      ],
      "env": {
        "PYTHONPATH": "E:\\trade\\aimicropay-tron\\python;E:\\trade\\aimicropay-tron\\python\\.vendor",
        "AIMIPAY_REPOSITORY_ROOT": "E:\\trade\\aimicropay-tron",
        "AIMIPAY_FULL_HOST": "http://127.0.0.1:9090",
        "AIMIPAY_MERCHANT_URLS": "http://127.0.0.1:8000"
      }
    }
  }
}
